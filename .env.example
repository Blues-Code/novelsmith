# novelsmith Environment Configuration
# Copy to .env and fill in your values

# LLM Provider (openai, anthropic, custom)
NOVELSMITH_LLM_PROVIDER=openai

# API Base URL (OpenAI-compatible endpoint)
NOVELSMITH_LLM_BASE_URL=https://api.openai.com/v1

# API Key
NOVELSMITH_LLM_API_KEY=sk-your-key-here

# Model name
NOVELSMITH_LLM_MODEL=gpt-4o

# Notifications (optional)
NOVELSMITH_TELEGRAM_BOT_TOKEN=
NOVELSMITH_TELEGRAM_CHAT_ID=
NOVELSMITH_FEISHU_WEBHOOK_URL=
NOVELSMITH_WECOM_WEBHOOK_URL=
